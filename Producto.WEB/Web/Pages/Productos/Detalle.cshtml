@page
@model Web.Pages.Productos.DetalleModel
@{
}
<header class="subhead">
    <div class="container">
        <div class="masthead-subheading">Programación Web Avanzada Johnnatan Chacón</div>
        <div class="masthead-heading text-uppercase">Busqueda de productos</div>
    </div>
</header>
<section class="page-section" id="services">
    <div class="container" style="max-width: fit-content;">
        <div class="text-center">
            <h2 class="section-heading text-uppercase">Detalle del producto</h2>
            <h3 class="section-subheading text-muted">Lista de los datos.</h3>
        </div>
        <div class="card mb-3 w-100 shadow-sm">
            <div class="row g-0">
                <div class="col-md-4" style="min-width: fit-content;">
                    <img src="~/assets/img/car.png" class="img-fluid vw-3 p-4 rounded-start" alt="...">
                </div>
                <div class="col-md-8">
                    <div class="card-body">
                        <h5 class="card-title">@Html.DisplayFor(subCategoria => subCategoria.producto.Categoria) @Html.DisplayFor(subCategoria => subCategoria.producto.Categoria)</h5>
                        <p class="card-text">
                            <div>
                                <b>@Html.DisplayNameFor(subCategoria => subCategoria.producto.Nombre): </b>
                                @Html.DisplayFor(subCategoria => subCategoria.producto.Nombre)
                            </div>
                            <div>
                                <b>@Html.DisplayNameFor(subCategoria => subCategoria.producto.Descripcion):</b>
                                @Html.DisplayFor(subCategoria => subCategoria.producto.Descripcion)
                            </div>
                            <div>
                                <b>@Html.DisplayNameFor(subCategoria => subCategoria.producto.Precio):</b>
                                @Html.DisplayFor(subCategoria => subCategoria.producto.Precio)
                            </div>
                        </p>
                        <p class="card-text"><small class="text-muted">@Html.DisplayFor(subCategoria => subCategoria.producto.CodigoBarras)</small></p>
                    </div>
                </div>
            </div>
        </div>
        <a class="btn btn-primary" asp-page="./Index">Regresar</a>
        <a class="btn btn-warning" asp-page="./Editar" asp-route-id="@Model.producto.Id">Editar</a>
    </div>
</section>